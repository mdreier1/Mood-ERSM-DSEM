TITLE: DSEM ERSM Depression;

DATA:
  FILE = mplus_data.dat;

VARIABLE:
  NAMES = pid hours ERSM Dep;
  USEVARIABLES = pid hours ERSM Dep;
  CLUSTER = pid;
  TINTERVAL = hours(3);
  LAGGED = Dep(1);
  MISSING = ALL(-999);

ANALYSIS:
  TYPE = TWOLEVEL RANDOM;
  ESTIMATOR = BAYES;
  BITERATIONS = (5000 100000);
  PROCESSORS = 4;
  THIN = 2;               !Set the thinning factor to 2 to increase stable estimations


MODEL:

%WITHIN%
  Dep ON Dep&1 (phi_dep);
  beta | Dep ON ERSM;

%BETWEEN%
  [Dep beta ERSM];       ! means of intercept, ERSM slope, and ERSM


OUTPUT:
		STANDARDIZED(CLUSTER) TECH1 TECH8 TECH4(CLUSTER);

PLOT:
        TYPE = PLOT1 PLOT2 PLOT3;	